# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: never expose in client code (Vercel → Environment Variables, disable "Expose to Browser")
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard default project (UUID from your `projects` table / seed)
NEXT_PUBLIC_PROJECT_ID=
